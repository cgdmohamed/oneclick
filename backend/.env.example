DATABASE_URL=postgres://hesabat:hesabat@localhost:5432/hesabat
JWT_SECRET=change-me-to-a-long-random-string-please
JWT_REFRESH_SECRET=change-me-too-long-random-different
PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Public app URL — used for links inside emails and shared invoice URLs
APP_URL=http://localhost:5173

# SMTP — leave blank to log emails to stdout instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Hesabat <no-reply@hesabat.local>

# SCL-06: set to false on extra replicas so jobs only tick on one instance.
RUN_JOBS=true

# SCL-07: pg pool tuning. Lower PG_POOL_MAX (e.g. 5) when fronted by PgBouncer
# and running many app replicas.
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=10000
